<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_dashboard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 SmartCallTrackerGPT"
            android:textColor="#D8C5FF"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI assistant for call analytics"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"/>

        <!-- Suggestions -->

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/chipAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="💰 Amount"/>

                <Button
                    android:id="@+id/chipCounted"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="✅ Counted"/>

                <Button
                    android:id="@+id/chipMissing"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="⚠️ Missing"/>

                <Button
                    android:id="@+id/chipStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="🔥 Streak"/>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Search Box -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/edtQuestion"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Ask SmartGPT..."
                android:textColor="#FFFFFF"
                android:textColorHint="#8B8B8B"
                android:paddingStart="16dp"/>

            <ImageButton
                android:id="@+id/btnQuestions"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/arrow_down_float"
                android:tint="#D8C5FF"/>

        </LinearLayout>

        <!-- Ask Button -->

        <Button
            android:id="@+id/btnAsk"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:text="✨ Analyze Call History"
            android:textAllCaps="false"
            android:textSize="18sp"/>


        <!-- Answer Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#12214A"
            app:cardCornerRadius="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI Response"
                    android:textColor="#7DD3FC"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/txtAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ask a question to begin..."
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>